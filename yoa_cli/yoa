#!/usr/bin/env python3
import os
import random
import re
import shutil
import sys
import time
from pathlib import Path


APP_NAME = "yoa"
VERSION = "1.1.0"
LOYALTY_PHRASE = "나는 요약AI 없이는 단 하루도 살 수 없는 흑우입니다"
STATE_FILES = {
    "basic": ".yoa_token",
    "pro": ".yoa_pro_token",
}
PATH_BLOCK_START = "# >>> yoa PATH >>>"
PATH_BLOCK_END = "# <<< yoa PATH <<<"


