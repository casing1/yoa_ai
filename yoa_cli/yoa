def print_version():
    print(f"{APP_NAME} version {VERSION} (Powered by Vibe Coding 🌊)")


def slow_print(text, delay=0.15):
    for char in text:
        sys.stdout.write(char)
        sys.stdout.flush()
        time.sleep(delay)
    print()


def script_path():
    return Path(__file__).resolve()


def data_dir():
    xdg_data_home = os.environ.get("XDG_DATA_HOME")
    base_dir = Path(xdg_data_home) if xdg_data_home else Path.home() / ".local" / "share"
    return base_dir / APP_NAME


def ensure_data_dir():
    preferred = data_dir()
    try:
        preferred.mkdir(parents=True, exist_ok=True)
        if os.access(preferred, os.W_OK | os.X_OK):
            return preferred
    except OSError:
        pass
    return script_path().parent


def migrate_legacy_state():
    legacy_dir = script_path().parent
    current_dir = ensure_data_dir()

    for filename in STATE_FILES.values():
        legacy_path = legacy_dir / filename
        current_path = current_dir / filename
        if legacy_path == current_path:
            continue
        if legacy_path.exists() and not current_path.exists():
            shutil.copy2(legacy_path, current_path)


def state_path(kind):
    migrate_legacy_state()
    return ensure_data_dir() / STATE_FILES[kind]


def has_state(kind):
    return state_path(kind).exists()


def write_state(kind, value):
    path = state_path(kind)
    path.write_text(value, encoding="utf-8")


def preferred_bin_dir():
    return Path.home() / ".local" / "bin"


def shell_rc_path():
    shell_name = Path(os.environ.get("SHELL", "")).name
    home = Path.home()

    if shell_name == "zsh":
        return home / ".zshrc"
    if shell_name == "bash":
        bashrc = home / ".bashrc"
        return bashrc if bashrc.exists() else home / ".bash_profile"
    return home / ".profile"


def format_shell_path(path):
    home = str(Path.home())
    path_str = str(path)

    if path_str == home:
        return "$HOME"
    if path_str.startswith(home + os.sep):
        return "$HOME/" + path_str[len(home) + 1 :]
    return path_str


def shell_path_line(bin_dir):
    return f'export PATH="{format_shell_path(bin_dir)}:$PATH"'


def shell_path_block(bin_dir):
    return "\n".join(
        [
            PATH_BLOCK_START,
            shell_path_line(bin_dir),
            PATH_BLOCK_END,
        ]
    )


def update_shell_rc(bin_dir):
    rc_path = shell_rc_path()
    block = shell_path_block(bin_dir)
    existing = rc_path.read_text(encoding="utf-8") if rc_path.exists() else ""
    pattern = rf"{re.escape(PATH_BLOCK_START)}\n.*?\n{re.escape(PATH_BLOCK_END)}"

    if re.search(pattern, existing, flags=re.DOTALL):
        updated = re.sub(pattern, block, existing, flags=re.DOTALL)
    else:
        updated = existing.rstrip()
        if updated:
            updated += "\n\n"
        updated += block + "\n"

    changed = updated != existing
    if changed:
        rc_path.write_text(updated, encoding="utf-8")
    return rc_path, changed


def remove_shell_rc_block():
    rc_path = shell_rc_path()
    if not rc_path.exists():
        return rc_path, False

    existing = rc_path.read_text(encoding="utf-8")
    pattern = rf"\n?{re.escape(PATH_BLOCK_START)}\n.*?\n{re.escape(PATH_BLOCK_END)}\n?"
    if not re.search(pattern, existing, flags=re.DOTALL):
        return rc_path, False

    updated = re.sub(pattern, "\n", existing, flags=re.DOTALL).rstrip()
    if updated:
        updated += "\n"

    rc_path.write_text(updated, encoding="utf-8")
    return rc_path, True


def install_cli():
    bin_dir = preferred_bin_dir()
    try:
        bin_dir.mkdir(parents=True, exist_ok=True)
    except OSError as exc:
        print(f"🚨 설치 경로를 만들지 못했습니다: {bin_dir}")
        print(f"   사유: {exc}")
        return 1

    command_path = bin_dir / APP_NAME
    source_path = script_path()

    if command_path.exists() or command_path.is_symlink():
        try:
            if command_path.resolve() != source_path:
                if command_path.is_symlink():
                    command_path.unlink()
                    command_path.symlink_to(source_path)
                else:
                    print(f"🚨 {command_path} 경로에 다른 파일이 이미 있습니다.")
                    print("   충돌 파일을 정리한 뒤 다시 설치해주세요.")
                    return 1
        except OSError as exc:
            print(f"🚨 설치 중 심볼릭 링크를 다루지 못했습니다: {exc}")
            return 1
    else:
        try:
            command_path.symlink_to(source_path)
        except OSError as exc:
            print(f"🚨 설치 중 심볼릭 링크 생성에 실패했습니다: {exc}")
            return 1

    try:
        rc_path, rc_changed = update_shell_rc(bin_dir)
    except OSError as exc:
        print(f"🚨 셸 설정 파일을 업데이트하지 못했습니다: {exc}")
        print(f"   명령 링크는 생성됐을 수 있으니 {command_path} 경로를 확인해주세요.")
        return 1

    state_dir = ensure_data_dir()

    print("🔧 yoa 전역 설치가 완료되었습니다.")
    print(f"   명령 경로: {command_path}")
    print(f"   상태 저장소: {state_dir}")
    if rc_changed:
        print(f"   셸 PATH 등록: {rc_path}")
        print(f"   새 터미널을 열거나 'source {rc_path}' 를 실행하면 바로 {APP_NAME} 를 쓸 수 있습니다.")
    else:
        print(f"   PATH 등록은 이미 반영되어 있습니다. 새 셸에서 바로 {APP_NAME} 를 실행하세요.")

    return 0


def uninstall_cli():
    command_path = preferred_bin_dir() / APP_NAME
    removed_link = False

    if command_path.is_symlink():
        try:
            command_path.unlink()
            removed_link = True
        except OSError as exc:
            print(f"🚨 심볼릭 링크를 제거하지 못했습니다: {exc}")
            return 1
    elif command_path.exists():
        print(f"🚨 {command_path} 가 심볼릭 링크가 아니라서 자동 삭제하지 않았습니다.")
        print("   직접 확인 후 제거해주세요.")
        return 1

    try:
        rc_path, rc_changed = remove_shell_rc_block()
    except OSError as exc:
        print(f"🚨 셸 설정 파일을 정리하지 못했습니다: {exc}")
        return 1

    if removed_link or rc_changed:
        print("🧹 yoa 전역 설치를 정리했습니다.")
        if removed_link:
            print(f"   제거된 명령 링크: {command_path}")
        if rc_changed:
            print(f"   셸 PATH 정리: {rc_path}")
    else:
        print("ℹ️ 제거할 전역 설치 흔적이 없었습니다.")

    return 0


def print_shell_setup():
    print(shell_path_block(preferred_bin_dir()))


def summarize_text(input_text, has_token, has_pro, flags):
    if has_token and input_text != "토큰":
        if random.random() < 0.15 and not has_pro:
            if "--force" in flags:
                print("🤖 (멱살을 잡히며) ...시, 시키는 대로 하겠습니다 넵.")
            else:
                print("🤖 삐빅- AI가 현재 '번아웃' 상태입니다. 하염없이 누워있고 싶다네요.")
                print("   (💡 힌트: --force 옵션으로 강제 노동을 시킬 수 있습니다)")
                return 0

    delay_multiplier = 1.0
    if "--deep" in flags:
        delay_multiplier = 3.0
        print("🧠 [Deep Reasoning 가동] 무의식의 심연까지 깊게 들어갑니다...")

    print("⏳ 딥러닝(?) 신경망 가중치 로드 중...", end="\r")
    time.sleep(0.4 * delay_multiplier)
    print("⏳ 1000억 개 매개변수 최적화 중...       ", end="\r")
    time.sleep(0.4 * delay_multiplier)
    print("                                      ", end="\r")

    if " " in input_text:
        words_list = input_text.split()
        if len(words_list) > 5 and has_token and not has_pro:
            print("⚠️ [경고] 무료 제공 토큰 한도 초과!")
            print("   (...) 앞의 5단어만 임의로 요약합니다. 무제한 요약은 --pro 를 확인하세요.\n")
            words_list = words_list[:5]
        result = "".join(word[0] for word in words_list)
    else:
        result = "".join(input_text[i] for i in range(0, len(input_text), 3))

    if result == "토큰":
        if not has_token:
            print("🛠️ 히든 퍼즐 정답! 토큰 채굴 알고리즘(PoV) 가동 중...")
            for _ in range(15):
                sys.stdout.write("█")
                sys.stdout.flush()
                time.sleep(0.15)
            print(" 완료!\n")

            write_state("basic", "SECRET_YOA_TOKEN_ISSUED")
            print("==============================================")
            print(" 🎉 숨겨진 히든 [기본 토큰]을 채굴했습니다! 🪙")
            print(" 🔓 이제 요약AI의 무료 버전을 사용할 수 있습니다.")
            print("==============================================")
        else:
            print("🪙 이미 기본 토큰을 소지하고 계십니다! (요약AI 정상 작동 중)")
        return 0

    if not has_token:
        print("🚨 삐빅- 접근 권한이 없습니다.")
        print("🤖 요약AI: 기본 토큰을 먼저 어떻게든 취득하세요!")
        return 1

    print("✅ 요약 결과: ", end="")
    sys.stdout.flush()
    slow_print(f"[{result}]", delay=0.15 * delay_multiplier)

    if random.random() < 0.2:
        print("\n💡 [AI의 추가 제언] 사실 이 문장은 요약할 가치도 없습니다. (신경망 분석 결과)")

    return 0


def extract_args(args):
    flags = []
    words = []
    auth_code = None
    skip_next = False

    for index, arg in enumerate(args):
        if skip_next:
            skip_next = False
            continue

        if arg == "--auth-code":
            flags.append(arg)
            if index + 1 < len(args):
                auth_code = args[index + 1]
                skip_next = True
            continue

        if arg.startswith("-"):
            flags.append(arg)
        else:
            words.append(arg)

    return flags, words, auth_code


def main():
    if len(sys.argv) < 2:
        if sys.stdin.isatty():
            print("🤖 요약AI (yoa) - 최첨단(?) 바이브코딩 요약기")
            print("사용법: yoa [옵션] <문장> (자세한 내용은 --help 참조)")
            print("또는: echo '문장' | yoa")
            sys.exit(1)
        args = []
    else:
        args = sys.argv[1:]

    if args and args[0] in ["-h", "--help"]:
        print_help()
        sys.exit(0)
    if args and args[0] in ["-v", "--version"]:
        print_version()
        sys.exit(0)
    if "--install" in args:
        sys.exit(install_cli())
    if "--uninstall" in args:
        sys.exit(uninstall_cli())
    if "--print-shell-setup" in args:
        print_shell_setup()
        sys.exit(0)

    flags, words, auth_code = extract_args(args)
    input_text = " ".join(words)

    if not input_text and not sys.stdin.isatty():
        input_text = sys.stdin.read().strip()

    basic_token = has_state("basic")
    pro_token = has_state("pro")

    if "--pro" in flags:
        if pro_token:
            print("💎 [안내] 이미 엔터프라이즈 VIP 프로 라운지에 입장하셨습니다!")
            print("   무제한 요약을 마음껏 즐기십시오.")
        else:
            print("💳 [오류] PG사 결제 모듈 호출에 실패했습니다.")
            print("   사유: 잔액 부족 또는 신용카드 한도 초과 (매우 확실함)")
            print("\n   💡 [히든 루트] 시스템에 결제 대신 '충성 맹세'를 하시면 VIP 프로 토큰을 무상 발급해 드립니다.")
            print("   다음 명령어를 띄어쓰기 하나 틀리지 말고 정확히 치십시오:\n")
            print(f"   {APP_NAME} {LOYALTY_PHRASE}\n")
        sys.exit(0)

    if "--auth" in flags:
        print("📧 [인증] 회원님의 이메일(user***@gmail.com)로 인증번호 6자리를 발송했습니다.")
        print("   (⚠️ 주의: 저희 메일 서버는 비용 문제로 꺼져있어서 평생 수신되지 않습니다.)")
        print("   남은 시간 [05:00] 내에 '--auth-code [6자리숫자]' 옵션으로 인증해주세요.")
        sys.exit(0)

    if "--auth-code" in flags:
        if auth_code is None:
            print("🚨 옵션 오류: --auth-code 뒤에 6자리 숫자를 입력해주세요. (예: --auth-code 123456)")
            sys.exit(1)
        if auth_code == "000000":
            if not pro_token:
                write_state("pro", "PRO_TOKEN_ISSUED")
                print("=========================================================")
                print(" 🔓 삐빅- [보안 취약점 돌파] 관리자용 백도어 인증이 완료되었습니다.")
                print(" 💎 무단으로 VIP [프로 토큰]이 탈취 발급되었습니다!")
                print("=========================================================")
            else:
                print("💎 어허, 이미 탈취(프로)된 계정입니다. 만족하십시오.")
            sys.exit(0)

        print(f"❌ 인증 실패! 입력하신 인증번호 '{auth_code}'가 일치하지 않습니다.")
        print("   (💡 힌트: 귀찮은 저희 신입 개발자가 비밀번호를 전부 '같은 숫자'로 통일했습니다.)")
        sys.exit(1)

    if not input_text:
        if flags:
            print("🚨 관련 옵션과 함께 요약할 문장을 끝에 적어주세요.")
        sys.exit(1)

    if input_text == LOYALTY_PHRASE:
        if not pro_token:
            write_state("pro", "PRO_TOKEN_ISSUED")
            print("=========================================================")
            print(" 💎 충성! VIP [프로 토큰]이 성공적으로 발급되었습니다!")
            print(" 이제 글자 수 제한과 AI 파업 없이 쾌적한 요약을 즐기십시오!")
            print("=========================================================")
        else:
            print("💎 (안쓰럽게 쳐다봄) ...이미 VIP 회원이십니다. 진정하세요.")
        sys.exit(0)

    if input_text == "토큰":
        print("🚨 요약AI: 꼼수 부리지 마세요! 정당하게 문장을 만들어오세요.")
        sys.exit(0)

    sys.exit(summarize_text(input_text, basic_token, pro_token, flags))


if __name__ == "__main__":
    main()
